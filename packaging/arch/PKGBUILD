# Maintainer: Your Name <you@example.com>
pkgname=wayspot-git
pkgver=0.1.0.r500.gbb659a5
pkgrel=1
pkgdesc="Spotlight-style launcher UI for Hyprland"
arch=('x86_64')
url="https://github.com/LaurenceGuws/wayspot"
license=('MIT')
depends=('glibc')
makedepends=('zig' 'git')
optdepends=('gtk4: enable GTK UI shell at build time')
provides=('wayspot')
conflicts=('wayspot')
_repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
source=("$pkgname::git+file://${_repo_root}")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$pkgname"
  printf "0.1.0.r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "$srcdir/$pkgname"
  # Default package build keeps GTK disabled for maximal portability.
  zig build -Doptimize=ReleaseSafe
}

check() {
  cd "$srcdir/$pkgname"
  zig build test -Doptimize=ReleaseSafe
}

package() {
  cd "$srcdir/$pkgname"
  install -Dm755 "zig-out/bin/wayspot" "$pkgdir/usr/bin/wayspot"
  install -Dm644 "packaging/desktop/wayspot.desktop" "$pkgdir/usr/share/applications/wayspot.desktop"
  install -Dm644 "assets/icons/wayspot.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/wayspot.svg"
  install -Dm644 "packaging/systemd/wayspot.service" "$pkgdir/usr/lib/systemd/user/wayspot.service"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
