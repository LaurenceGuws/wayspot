{
  "title": "wayspot Docs Explorer",
  "icon": "/__repo_root/assets/icons/wayspot.svg",
  "repoBasePath": "/__repo_root/",
  "repoUrl": "https://github.com/LaurenceGuws/wayspot",
  "runtimeMode": "local-dev",
  "defaultDoc": "README.md",
  "docsIndexPath": "./docs-index.wayspot.json",
  "theme": {
    "dark": {
      "accent": "#58d0ff",
      "accentSoft": "rgba(88, 208, 255, 0.14)",
      "accentStrong": "#8be0ff",
      "activeLink": "#d8f7ff",
      "panel": "#101b22",
      "panel2": "#15212a",
      "panel3": "#1b2a34",
      "bg": "#0b1218",
      "bg2": "#111a22"
    },
    "light": {
      "accent": "#117aa6",
      "accentSoft": "rgba(17, 122, 166, 0.12)",
      "accentStrong": "#0d6488",
      "activeLink": "#0d3d52",
      "panel": "#edf7fa",
      "panel2": "#f7fcfd",
      "panel3": "#dbeef3",
      "bg": "#e5f1f5",
      "bg2": "#d4e6ec"
    }
  },
  "docRoots": [
    ".",
    "docs",
    "workstreams"
  ],
  "includeExtensions": [
    ".md",
    ".yaml"
  ]
}
